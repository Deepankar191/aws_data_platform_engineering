  <diagram id="3. Identity resolution flow" name="3. Identity resolution flow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="START" value="Source row to resolve
(AECB / Fraud / AML)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="320" y="20" width="230" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="SPINE" value="Spine = PostgreSQL internal_customer_uuid
master_customer_id = UUIDv5(internal_uuid)
stable &amp; reproducible" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#e1ecf4;strokeColor=#2e6da4;" vertex="1" parent="1">
          <mxGeometry x="620" y="20" width="300" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="DET" value="Deterministic match?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fdebd0;strokeColor=#b9770e;" vertex="1" parent="1">
          <mxGeometry x="360" y="130" width="150" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="ACCEPT" value="Accept
match_confidence = 1.00
match_method = DETERMINISTIC" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#d4efdf;strokeColor=#1e8449;" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="230" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="PROB" value="Probabilistic scorer
weighted Jaro-Winkler on name
+ exact on dob/phone/email/eid" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#e1ecf4;strokeColor=#2e6da4;" vertex="1" parent="1">
          <mxGeometry x="360" y="250" width="230" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="MULTI" value="Candidates?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fdebd0;strokeColor=#b9770e;" vertex="1" parent="1">
          <mxGeometry x="400" y="370" width="150" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="TAKEBEST" value="Take highest-scoring candidate
record match_confidence" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#d4efdf;strokeColor=#1e8449;" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="230" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="REVIEW" value="Attach BUT flag
needs_manual_review = TRUE" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fcf3cf;strokeColor=#b7950b;" vertex="1" parent="1">
          <mxGeometry x="340" y="490" width="230" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="UNRES" value="Create UNRESOLVED record
master_customer_id = UNRESOLVED
(no source data dropped)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f5b7b1;strokeColor=#c0392b;" vertex="1" parent="1">
          <mxGeometry x="640" y="490" width="230" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="SURV" value="Conflicting attributes
across sources?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fdebd0;strokeColor=#b9770e;" vertex="1" parent="1">
          <mxGeometry x="340" y="610" width="170" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="SURVRULE" value="Survivorship:
POSTGRES &gt; AECB &gt; FRAUD &gt; AML
most-recent-timestamp wins in a tie" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#e1ecf4;strokeColor=#2e6da4;" vertex="1" parent="1">
          <mxGeometry x="40" y="610" width="230" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="WRITE" value="Write to customer_identity_xref
match_method · match_confidence · matched_on
needs_manual_review · audit timestamps" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#e1ecf4;strokeColor=#2e6da4;" vertex="1" parent="1">
          <mxGeometry x="320" y="730" width="300" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="XREFOUT" value="customer_identity_xref
golden record, SCD2 history" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#d4efdf;strokeColor=#1e8449;" vertex="1" parent="1">
          <mxGeometry x="340" y="840" width="230" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="START" target="DET">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="seeds" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;endArrow=open;strokeColor=#7f8c8d;" edge="1" parent="1" source="SPINE" target="DET">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="EID exact / phone+email exact" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="DET" target="ACCEPT">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" value="partial / fuzzy · AML soundex+dob" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="DET" target="PROB">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="PROB" target="MULTI">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" value="best ≥ 0.85 (MATCH)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="MULTI" target="TAKEBEST">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7" value="0.70 ≤ best &lt; 0.85 (REVIEW)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="MULTI" target="REVIEW">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e8" value="best &lt; 0.70" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="MULTI" target="UNRES">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="ACCEPT" target="SURV">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="TAKEBEST" target="SURV">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="REVIEW" target="SURV">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e12" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="SURV" target="SURVRULE">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e13" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="SURV" target="WRITE">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e14" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="SURVRULE" target="WRITE">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e15" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="UNRES" target="WRITE">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e16" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#42556b;" edge="1" parent="1" source="WRITE" target="XREFOUT">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
